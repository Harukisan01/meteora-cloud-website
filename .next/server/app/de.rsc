8:["$","$L9",null,{"locale":"de","now":"$D2026-03-02T19:58:50.337Z","timeZone":"Europe/Rome","messages":{"Hero":{"title":"Cloud-Infrastruktur","subtitle":"Unternehmensgerechte Cloud-Architekturen für CEOs, CTOs und IT-Manager. Keine Ausfallzeiten, maximale Leistung und garantierte Kostensenkung.","cta":"Kostenlose Cloud-Beratung buchen"},"Services":{"title":"Unsere IT-Lösungen","subtitle":"Unternehmens-Technologien, die auf maximale Effizienz und Sicherheit Ihres Unternehmens zugeschnitten sind.","arch":"Cloud Architecture","arch_desc":"Wir entwerfen Enterprise-Grade-Infrastrukturen auf Amazon Web Services und Microsoft Azure. Wir migrieren Ihre Verwaltungssoftware in die Cloud und führen sichere Migrationen ohne Ausfallzeiten durch.","sec":"Security Audit & Compliance","sec_desc":"Finden Sie Schwachstellen, bevor Hacker es tun. Wir führen vollständige Audits Ihrer Infrastruktur durch, um Zertifizierungen und DSGVO-Konformität sicherzustellen.","fin":"FinOps & Cost Optimization","fin_desc":"Wir analysieren Ihre aktuellen Cloud-Ausgaben und reduzieren versteckte Verschwendung. Gewinnen Sie die Kontrolle über Ihre IT-Rechnungen zurück.","dev":"DevOps & Serverless","dev_desc":"Wir automatisieren Software-Release-Prozesse und bauen Serverless-Architekturen, die von 0 auf Millionen von Benutzern skalieren, ohne Server verwalten zu müssen."},"Creation":{"badge":"Cloud Solution Architecting","title":"Entwurf und Implementierung","desc":"Von der Idee bis zur Ready-for-Production. Wir erstellen sichere, skalierbare und sofort einsatzbereite AWS-, Azure- und GCP-Umgebungen.","p1_title":"Enterprise Landing Zones","p1_desc":"Automatische Governance, Networking (Hub & Spoke) und Security-Einrichtung auf AWS und Azure.","p2_title":"App Modernization","p2_desc":"Übergang von Monolithen zu Microservices und Serverless (Lambda / Azure Functions).","p3_title":"Infrastructure-as-Code Setup","p3_desc":"Jede erstellte Ressource wird per Terraform dokumentiert und verwaltet. Kein manuelles Klicken.","stack_title":"Tech Stack","stack_desc":"Wie wir Ihre Ready-for-Production-Infrastruktur aufbauen.","col_sol":"Lösung","col_tech":"Tech Stack","col_vantaggio":"Wettbewerbsvorteil","c1_v":"Vertraglich garantierte 99,99 % Verfügbarkeit.","c2_v":"Agilität bei der Anwendungsbereitstellung.","c3_v":"Cost Optimization: Sie zahlen nur für das, was Sie nutzen.","c4_v":"Automatisierte Compliance ohne menschliches Eingreifen."},"About":{"badge":"Certified Cloud Architect","title":"Über mich","desc":"Ich bin ein Cloud-Architekt, der sich auf den Entwurf und die Sicherung umfangreicher Infrastrukturen spezialisiert hat. In den letzten Jahren habe ich Dutzenden von Unternehmen geholfen, in die Cloud zu migrieren, Betriebskosten zu senken und Veröffentlichungen mit Terraform zu automatisieren. Ich bin keine Agentur, die Arbeit delegiert: Ich entwerfe und lege persönlich Hand an."}},"children":[["$","$La",null,{}],["$","$L5",null,{"parallelRouterKey":"children","segmentPath":["children","$b","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined","styles":null}],["$","$Lc",null,{}]]}]

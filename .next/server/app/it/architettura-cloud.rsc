9:["$","$La",null,{"locale":"it","now":"$D2026-03-02T19:58:50.371Z","timeZone":"Europe/Rome","messages":{"Hero":{"title":"Infrastrutture Cloud","subtitle":"Architetture cloud di livello enterprise studiate per CEO, CTO e IT Manager. Zero downtime, massime performance e riduzione dei costi garantita.","cta":"Prenota una Consulenza Cloud Gratuita"},"Services":{"title":"Le nostre soluzioni IT","subtitle":"Tecnologie enterprise adattate per massimizzare l'efficienza e la sicurezza del tuo business.","arch":"Cloud Architecture","arch_desc":"Progettiamo infrastrutture di livello enterprise su Amazon Web Services e Microsoft Azure. Migriamo i tuoi gestionali sul Cloud ed eseguiamo migrazioni sicure e senza disservizi.","sec":"Security Audit & Compliance","sec_desc":"Trova le vulnerabilità prima degli hacker. Eseguiamo Audit completi della tua infrastruttura per garantirti certificazioni e conformità GDPR.","fin":"FinOps & Cost Optimization","fin_desc":"Analizziamo la tua attuale spesa cloud e tagliamo gli sprechi nascosti. Riprendi il controllo delle tue bollette IT.","dev":"DevOps & Serverless","dev_desc":"Automatizziamo i processi di rilascio del software e costruiamo architetture Serverless che scalano da 0 a milioni di utenti senza dover gestire i server."},"Creation":{"badge":"Cloud Solution Architecting","title":"Progettazione e Creazione","desc":"Dall'idea al Ready-for-Production. Creiamo ambienti AWS, Azure e GCP sicuri, scalabili e pronti all'uso.","p1_title":"Enterprise Landing Zones","p1_desc":"Governance, Networking (Hub & Spoke) e Security set-up automatico su AWS e Azure.","p2_title":"App Modernization","p2_desc":"Passaggio da Monoliti a Microservizi e Serverless (Lambda / Azure Functions).","p3_title":"Infrastructure-as-Code Setup","p3_desc":"Ogni risorsa creata è documentata e gestita via Terraform. No manual clicks.","stack_title":"Tech Stack","stack_desc":"Come costruiamo la tua infrastruttura Ready-for-Production.","col_sol":"Soluzione","col_tech":"Tech Stack","col_vantaggio":"Vantaggio Competitivo","c1_v":"99.99% Uptime garantito bloccato per contratto.","c2_v":"Agilità nel Deployment delle applicazioni.","c3_v":"Cost Optimization: paghi solo quello che usi.","c4_v":"Compliance automatizzata senza interventi umani."},"About":{"badge":"Certified Cloud Architect","title":"Chi sono","desc":"Sono un Cloud Architect specializzato nella progettazione e messa in sicurezza di infrastrutture su larga scala. Negli ultimi anni ho aiutato decine di aziende a migrare sul Cloud, ridurre i costi operativi e automatizzare i rilasci con Terraform. Non sono un'agenzia che delega il lavoro: progetto e metto le mani in pasta personalmente."}},"children":[["$","$Lb",null,{}],["$","$L3",null,{"parallelRouterKey":"children","segmentPath":["children","$4","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L5",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined","styles":null}],["$","$Lc",null,{}]]}]
